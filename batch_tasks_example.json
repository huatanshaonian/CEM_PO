{
  "global_settings": {
    "output_dir": "results/batch_example",
    "log_dir": "results/batch_example/logs",
    "save_plot": true,
    "filename_format": "{task_name}"
  },
  "tasks": [
    {
      "name": "Cylinder_1GHz_Standard",
      "description": "标准圆柱体 RCS 验证，使用离散 PO 旗舰算法",
      "geometry": {
        "type": "Cylinder",
        "params": {
          "radius": 0.5,
          "height": 2.0
        }
      },
      "solver": {
        "frequency_mhz": 1000.0,
        "algorithm": "discrete_po_sinc_dual",
        "po_precision": "double",
        "mesh_density": 10.0,
        "use_degenerate": true,
        "polarization": "VV"
      },
      "scan": {
        "theta": [0, 180, 181],
        "phi": [0, 0, 1]
      }
    },
    {
      "name": "Plate_PTD_VV_HH",
      "description": "带有 PTD 边缘修正的正方形平板",
      "geometry": {
        "type": "Plate",
        "params": {
          "width": 1.0,
          "length": 1.0
        }
      },
      "solver": {
        "frequency_mhz": 3000.0,
        "algorithm": "discrete_po_sinc_dual",
        "polarization": "VV",
        "ptd": {
          "enabled": true,
          "edges": "0,1,2,3",
          "seg_angle_deg": 2.0,
          "use_parallel_ptd": true
        }
      },
      "scan": {
        "theta": [-90, 90, 181],
        "phi": [0, 0, 1]
      }
    },
    {
      "name": "Plate_Freq_Sweep",
      "description": "宽带频率扫描，生成高分辨率距离像 (1D Range Profile)",
      "geometry": {
        "type": "Plate",
        "params": {
          "width": 0.5,
          "length": 0.5
        }
      },
      "solver": {
        "algorithm": "discrete_po_sinc_dual",
        "po_precision": "mixed",
        "polarization": "VV"
      },
      "scan": {
        "theta": [0, 0, 1],
        "phi": [0, 0, 1]
      },
      "freq_sweep": {
        "enabled": true,
        "f_start": 1000.0,
        "f_end": 5000.0,
        "f_step": 10.0,
        "window": "hamming",
        "zero_pad": 4,
        "polarization": "VV"
      }
    },
    {
      "name": "IGES_Advanced_Fix",
      "description": "加载 IGES 文件并应用高级修正（镜像、旋转、删除特定面）",
      "geometry": {
        "type": "IGES File",
        "params": {
          "file_path": "models/complex_part.igs",
          "unit": "mm",
          "mirror_plane": "XZ",
          "rotation": [0, 0, 45],
          "delete_indices": [10, 11, 12],
          "invert_indices": [1, 2, 3]
        }
      },
      "solver": {
        "frequency_mhz": 1500.0,
        "algorithm": "gauss_ribbon",
        "use_gpu": true
      },
      "scan": {
        "theta": [0, 360, 361],
        "phi": [0, 0, 1]
      }
    },
    {
      "name": "Batch_Folder_Scan",
      "description": "自动遍历文件夹下所有的 IGES 和 STEP 模型并批量执行",
      "geometry": {
        "type": "IGES File",
        "params": {
          "folder_path": "models/my_parts",
          "unit": "mm"
        }
      },
      "solver": {
        "frequency_mhz": 1200.0,
        "algorithm": "discrete_po_sinc_dual"
      },
      "scan": {
        "theta": [0, 90, 91],
        "phi": [0, 0, 1]
      }
    },
    {
      "name": "Sphere_2D_Scan",
      "description": "球体 2D 全空间扫描案例",
      "geometry": {
        "type": "Sphere",
        "params": {
          "radius": 1.0
        }
      },
      "solver": {
        "frequency_mhz": 500.0,
        "algorithm": "discrete_po_sinc_dual"
      },
      "scan": {
        "theta": [0, 180, 37],
        "phi": [0, 360, 73]
      }
    }
  ]
}